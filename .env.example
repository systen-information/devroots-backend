# Copy this to .env and fill in your values

# Get this from Supabase → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.XXXXX.supabase.co:5432/postgres

# Generate a random secret (any long random text)
JWT_SECRET=your-secret-key-change-this-to-something-random

# Your Netlify website URL
FRONTEND_URL=https://devroots.netlify.app

# Server port (Render sets this automatically)
PORT=3001
